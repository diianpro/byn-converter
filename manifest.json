{
  "manifest_version": 3,
  "name": "BYN Converter",
  "version": "0.1.0",
  "description": "Конвертирует цены в белорусских рублях в USD/EUR/RUB по курсу НБ РБ",
  "permissions": ["storage", "alarms", "scripting", "activeTab"],
  "host_permissions": [
    "https://*.kufar.by/*",
    "https://*.realt.by/*",
    "https://*.av.by/*",
    "https://api.nbrb.by/*"
  ],
  "optional_host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.kufar.by/*",
        "https://*.realt.by/*",
        "https://*.av.by/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "BYN Converter"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
